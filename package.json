{
	"name": "uru",
	"version": "0.1.1",
	"description": "Knowledge graph + vector search for your vault, powered by khora.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "node scripts/install-to-vault.mjs",
		"install-plugin": "npm run build && node scripts/install-to-vault.mjs",
		"verify": "node scripts/verify-staging.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"knowledge-graph"
	],
	"author": "Arsenije",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"@typescript-eslint/eslint-plugin": "5.29.0",
		"@typescript-eslint/parser": "5.29.0",
		"builtin-modules": "3.3.0",
		"esbuild": "0.17.3",
		"obsidian": "latest",
		"tslib": "2.4.0",
		"typescript": "4.7.4"
	}
}
