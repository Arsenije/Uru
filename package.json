{
	"name": "uru",
	"version": "0.1.13",
	"description": "Search and chat with your vault using local AI — private, offline, powered by Khora.",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"deploy": "node scripts/install-to-vault.mjs",
		"install-plugin": "npm run build && node scripts/install-to-vault.mjs",
		"test": "node scripts/run-tests.mjs",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"typecheck": "tsc --noEmit",
		"verify": "node scripts/verify-staging.mjs",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"semantic-search"
	],
	"author": "Arsenije",
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^18.19.0",
		"esbuild": "0.17.3",
		"eslint": "^9.39.0",
		"eslint-plugin-obsidianmd": "^0.4.1",
		"obsidian": "1.13.1",
		"tslib": "2.4.0",
		"typescript": "^5.9.0",
		"typescript-eslint": "^8.64.0"
	}
}
